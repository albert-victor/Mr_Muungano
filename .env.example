# OpenRouter API key — https://openrouter.ai/keys (LAZIMA kwa majibu ya AI)
OPENROUTER_API_KEY=your_key_here

# Model (change without touching code)
OPENROUTER_MODEL=google/gemini-2.5-flash

# Optional — Hugging Face token (SI LAZIMA)
# Inatumika tu kupakua embedding model haraka zaidi. Bila hii app bado inafanya kazi.
# https://huggingface.co/settings/tokens
# HF_TOKEN=hf_xxxxxxxx

# Optional overrides

# CHROMA_DIR=data/chroma

# PDF_DIR=pdf

# EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# RETRIEVAL_K=8

# CONTEXT_CHUNK_MAX_CHARS=900

# CHUNK_MIN_TOKENS=600

# CHUNK_MAX_TOKENS=800

# CHUNK_OVERLAP_TOKENS=100

